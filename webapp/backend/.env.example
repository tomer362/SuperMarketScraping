# SuperMarket Web App — Backend Configuration
# Copy this file to .env and adjust values as needed.

# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/supermarket

# How often (in hours) to automatically re-scrape all supermarkets
SCRAPE_INTERVAL_HOURS=6

# Server bind (uvicorn)
HOST=0.0.0.0
PORT=8000
